# 서버 설정
PORT=3001
NODE_ENV=development

# 국토교통부 실거래가 API 키 (data.go.kr에서 발급)
MOLIT_API_KEY=your_molit_api_key_here

# CORS 허용 도메인 (쉼표 구분)
ALLOWED_ORIGINS=http://localhost:5173

# 카카오 REST API 키 (서버사이드 Geocoding용 — 카카오 개발자 콘솔에서 발급)
KAKAO_REST_API_KEY=your_kakao_rest_api_key_here

# 국토부 실거래가 Cloudflare Workers 프록시 URL (기본값 내장, 변경 시만 설정)
MOLIT_PROXY_URL=https://molit-proxy.bomzip.workers.dev/trade

# 뉴스 API 키 (선택사항, 향후 확장용)
NEWS_API_KEY=
